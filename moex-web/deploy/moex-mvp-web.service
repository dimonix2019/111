[Unit]
Description=MOEX MVP Web (moex-web)
After=network-online.target tailscaled.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/moex-111/moex-web
Environment=MOEX_WEB_HOST=0.0.0.0
Environment=MOEX_WEB_PORT=8080
Environment=PYTHONPATH=/opt/moex-111/moex-web:/opt/moex-111/strategy-web
ExecStart=/opt/moex-111/moex-web/deploy/run.sh
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
